# ============================================================
# Exemple de configuration de PROD (LAN strict, HTTP only).
# Copier en .env.prod et remplacer les "changeme" par des secrets réels.
# Le vrai .env.prod n'est JAMAIS committé (voir .gitignore).
# ============================================================

# Module de settings (manage.py / wsgi font setdefault sur dev → forcer ici)
DJANGO_SETTINGS_MODULE=config.settings.prod

DJANGO_DEBUG=False
DJANGO_SECRET_KEY=changeme
DJANGO_ALLOWED_HOSTS=budgets.core.home.arpa,backend
CSRF_TRUSTED_ORIGINS=http://budgets.core.home.arpa

POSTGRES_DB=budgettracker
POSTGRES_USER=budget
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://budget:changeme@db:5432/budgettracker
